    <!-- ========== 推理测试：类继承关系 ========== -->
    <!-- 定义父类：所有医疗相关人员 -->
    <owl:Class rdf:about="http://example.com/ontology#person"/>

    <!-- doctor 是 person 的子类（医生也是人） -->
    <owl:Class rdf:about="http://example.com/ontology#doctor">
        <rdfs:subClassOf rdf:resource="http://example.com/ontology#person"/>
    </owl:Class>

    <!-- patient 是 person 的子类（病人也是人） -->
    <owl:Class rdf:about="http://example.com/ontology#patient">
        <rdfs:subClassOf rdf:resource="http://example.com/ontology#person"/>
    </owl:Class>

    <!-- infectious_disease 是 disease 的子类（传染病是一种疾病） -->
    <owl:Class rdf:about="http://example.com/ontology#infectious_disease">
        <rdfs:subClassOf rdf:resource="http://example.com/ontology#disease"/>
    </owl:Class>

    <!-- 定义 disease 类 -->
    <owl:Class rdf:about="http://example.com/ontology#disease"/>

    <!-- ========== 推理测试：等价类关系 ========== -->
    <!-- 如果 doctor 和 physician 表示同一种事物 -->
    <owl:Class rdf:about="http://example.com/ontology#doctor">
        <owl:equivalentClass rdf:resource="http://example.com/ontology#physician"/>
    </owl:Class>
